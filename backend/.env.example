# =================================================================
# SSI VOTING - ENVIRONMENT VARIABLES TEMPLATE
# Kullanim: cp .env.example .env  (sonra degerleri duzelt)
# DIKKAT: .env dosyasini Git'e commit ETME!
# Production icin Render Dashboard > Environment'tan setle.
# =================================================================

# -- Blockchain ---------------------------------------------------
# Lokal: Hardhat test hesabi #0 (sadece dev). Production: Sepolia ozel anahtarini koy.
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Lokal: http://127.0.0.1:8545 | Sepolia: https://ethereum-sepolia-rpc.publicnode.com
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
RPC_URL=http://127.0.0.1:8545

# Deploy sonrasi otomatik doldurulur - ya da elle gir
VOTING_CONTRACT_ADDRESS=
SSI_CONTRACT_ADDRESS=

# Hardhat local: 31337 | Sepolia: 11155111
CHAIN_ID=31337

# -- Backend ------------------------------------------------------
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# JWT/Session: production'da MUTLAKA yeniden uret -> openssl rand -hex 48
JWT_SECRET=change_this_to_a_long_random_string_in_production
SESSION_SECRET=change_this_to_a_long_random_string_in_production
SESSION_TIMEOUT=28800000

# Persistent disk path (Render'da /var/data/database.db, lokalde bos birak)
# DB_PATH=/var/data/database.db

# -- CORS ---------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
FRONTEND_URL=http://localhost:3000

# -- Guvenlik -----------------------------------------------------
BCRYPT_SALT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
WALLET_ENCRYPTION_KEY=change_this_in_production

# -- SMTP (OTP icin) ---------------------------------------------
# Office365: app password kullan (https://account.microsoft.com/security)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM="SSI Voting <noreply@yourdomain.com>"

# -- Debug (sadece gelistirme) ------------------------------------
DEBUG=false
MOCK_BLOCKCHAIN=false
DEBUG_OTP=false
SKIP_SIGNATURE_VERIFICATION=false