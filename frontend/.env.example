# Frontend Environment Variables (CRA)
# .env.local olarak dev'de, Vercel'da Project Settings > Environment Variables üzerinden set edilir.

# Backend kök URL'i (yeterli) — diğerleri otomatik türetilir.
REACT_APP_API_URL=http://localhost:5000

# (Opsiyonel) Manuel override istersen:
# REACT_APP_API_BASE_URL=http://localhost:5000/api
# REACT_APP_SOCKET_URL=http://localhost:5000
