# ========================================
# BLOCKCHAIN ANONYMOUS VOTING - ENV CONFIG
# ========================================
#
# CRITICAL SECURITY NOTES:
# 1. NEVER commit the actual .env file to Git
# 2. Add .env to .gitignore
# 3. Share this .env.example file instead
# 4. For production, use environment-specific secrets management

# ========================================
# ADMIN PRIVATE KEY (VOTE AUTHORIZATION)
# ========================================
# 
# This private key is used by the backend to sign vote authorizations.
# The corresponding public address must be set as admin in the smart contract.
#
# DEVELOPMENT ONLY - Use a test wallet (e.g., from Hardhat's default accounts)
# DO NOT USE A REAL WALLET WITH MAINNET FUNDS
#
# Example: Hardhat's first default account private key
# (Only use this for local development, NEVER in production)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ========================================
# DATABASE CONNECTION
# ========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DB_CONNECTION_STRING=postgresql://postgres:password@localhost:5432/online_voting

# Alternatively, use individual parameters:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=online_voting
DB_USER=postgres
DB_PASSWORD=password

# ========================================
# BLOCKCHAIN CONNECTION
# ========================================
# Ethereum RPC URL for connecting to the blockchain
# Local development: http://127.0.0.1:8545 (Hardhat node)
# Sepolia testnet: Use Infura/Alchemy URL
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Smart contract address (set after deployment)
VOTING_CONTRACT_ADDRESS=

# Chain ID
# Local Hardhat: 31337
# Sepolia: 11155111
CHAIN_ID=31337

# ========================================
# BACKEND SERVER CONFIG
# ========================================
PORT=5000
NODE_ENV=development

# Session secret for JWT or session management
SESSION_SECRET=your_random_session_secret_here_change_in_production

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ========================================
# FRONTEND CONFIG (React .env)
# ========================================
# Note: Create a separate .env file in client/ folder for React
# React variables must start with REACT_APP_
#
# Example client/.env:
# REACT_APP_BACKEND_URL=http://localhost:5000
# REACT_APP_CONTRACT_ADDRESS=<deployed_contract_address>
# REACT_APP_CHAIN_ID=31337

# ========================================
# SECURITY SETTINGS
# ========================================
# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Session timeout (in milliseconds)
SESSION_TIMEOUT=3600000

# ========================================
# TESTING & DEVELOPMENT
# ========================================
# Enable verbose logging
DEBUG=true

# Mock blockchain (for testing without Hardhat node)
MOCK_BLOCKCHAIN=false

# Skip signature verification (DANGEROUS - only for testing)
SKIP_SIGNATURE_VERIFICATION=false